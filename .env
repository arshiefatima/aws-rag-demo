# Copy to .env — NO API KEYS NEEDED for this project!

# ChromaDB storage path
CHROMA_PATH=/mnt/efs/chroma
CHROMA_COLLECTION=rag_docs

# Free local embedding model (downloads automatically on first run)
EMBED_MODEL=all-MiniLM-L6-v2

# Ollama local LLM settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# AWS (only needed if deploying to cloud — not needed for local testing)
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-rag-docs-bucket

# API URL (fill in after running: make deploy)
API_URL=
